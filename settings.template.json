{
  "model": "opus[1m]",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_OBSIDIAN_DIR": ""
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Edit(~/claude/scratch/**)",
      "Write(~/claude/scratch/**)",
      "Edit(~/claude/obsidian/**)",
      "Write(~/claude/obsidian/**)",
      "Skill(api-key-checker)",
      "Skill(ask-questions)",
      "Skill(claude-code-config)",
      "Skill(concise-writing)",
      "Skill(constitution)",
      "Skill(data-science)",
      "Skill(discussion-partners)",
      "Skill(forecast)",
      "Skill(gh-cli)",
      "Skill(gws-cli)",
      "Skill(heavy)",
      "Skill(heartbeat)",
      "Skill(jina-grep)",
      "Skill(kaggle)",
      "Skill(knowledge-system)",
      "Skill(lean-prover)",
      "Skill(llm-judge)",
      "Skill(mental-models)",
      "Skill(melt)",
      "Skill(modal)",
      "Skill(orchestrate)",
      "Skill(pdf-to-markdown)",
      "Skill(pr-review)",
      "Skill(prior-art-review)",
      "Skill(private-repo)",
      "Skill(prompt-evolution)",
      "Skill(ralph-loop)",
      "Skill(rlm)",
      "Skill(session-lifecycle)",
      "Skill(skillcraft)",
      "Skill(slack-bridge)",
      "Skill(staff-engineer)",
      "Skill(superforecaster)",
      "Skill(trufflehog)",
      "Skill(ultra-think)",
      "Skill(web-grab)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(gh api *-X DELETE*)",
      "Bash(gh api *--method DELETE*)",
      "Bash(gh api *-X PUT*)",
      "Bash(gh api *--method PUT*)",
      "Bash(gh api *-X PATCH*)",
      "Bash(gh api *--method PATCH*)",
      "Bash(gh auth login*)",
      "Bash(gh auth logout*)",
      "Bash(gh auth refresh*)",
      "Bash(gh auth token*)",
      "Bash(gh auth status --show-token*)",
      "Bash(gh auth status -t*)",
      "Bash(gh cache delete*)",
      "Bash(gh codespace create*)",
      "Bash(gh codespace delete*)",
      "Bash(gh config set*)",
      "Bash(gh gpg-key add*)",
      "Bash(gh gpg-key delete*)",
      "Bash(gh gist create*)",
      "Bash(gh gist delete*)",
      "Bash(gh gist edit*)",
      "Bash(gh issue delete*)",
      "Bash(gh issue transfer*)",
      "Bash(gh label create*)",
      "Bash(gh label delete*)",
      "Bash(gh label edit*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr reopen*)",
      "Bash(gh pr revert*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh release upload*)",
      "Bash(gh repo archive*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit*)",
      "Bash(gh repo fork*)",
      "Bash(gh repo rename*)",
      "Bash(gh repo unarchive*)",
      "Bash(gh run cancel*)",
      "Bash(gh run delete*)",
      "Bash(gh run rerun*)",
      "Bash(gh secret delete*)",
      "Bash(gh secret set*)",
      "Bash(gh ssh-key add*)",
      "Bash(gh ssh-key delete*)",
      "Bash(gh ssh-key list*)",
      "Bash(gh variable delete*)",
      "Bash(gh variable set*)",
      "Bash(gh workflow disable*)",
      "Bash(gh workflow enable*)",
      "Bash(gh workflow run*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "find ~/.claude/plugins -name '*.sh' -type f ! -perm -u+x -exec chmod +x {} +",
            "timeout": 10,
            "statusMessage": "Fixing plugin hook permissions..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
